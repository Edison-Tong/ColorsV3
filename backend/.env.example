# ColorsV3 backend configuration.
#
# Local development: leave DATABASE_URL UNSET — the server uses a local SQLite file
# (backend/colorsv3.db), zero setup.
#
# Production: set DATABASE_URL to your Postgres connection string (e.g. from Neon) and
# the server automatically uses Postgres instead. Neon's string already requires SSL.
#
# DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

# Port (Render/host sets this automatically; defaults to 4000 locally).
# PORT=4000

# Set to "disable" only for a plain local Postgres without TLS. Leave unset for Neon/Render.
# PGSSL=disable
